{
  "name": "soluna",
  "version": "2.5.2",
  "description": "JavaScript library for converting between Gregorian (solar) and Chinese lunar calendar dates",
  "main": "soluna.js",
  "types": "soluna.d.ts",
  "bin": {
    "soluna": "bin/soluna.js"
  },
  "files": [
    "soluna.js",
    "soluna.d.ts",
    "bin/soluna.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "biome check soluna.js test/soluna.test.mjs examples/run.js",
    "test": "node --test test/soluna.test.mjs",
    "test:watch": "node --test --watch test/soluna.test.mjs",
    "dev": "node examples/run.js"
  },
  "keywords": [
    "lunar",
    "calendar",
    "chinese",
    "solar",
    "gregorian",
    "zodiac",
